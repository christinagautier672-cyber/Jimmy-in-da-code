<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Love OS // Aero Edition 💙</title>

<style>
body {
  margin: 0;
  font-family: "Segoe UI", Arial, sans-serif;
  overflow: hidden;
  color: white;
  background: radial-gradient(circle at top, #6ee7ff, #0b1020);
}

/* 🌊 AERO BACKGROUND LIGHT WAVES */
.bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.25), transparent 40%),
    radial-gradient(circle at 80% 70%, rgba(0,255,255,0.18), transparent 45%),
    radial-gradient(circle at 50% 50%, rgba(255,255,255,0.08), transparent 60%);
  animation: floatBG 12s ease-in-out infinite alternate;
  z-index: -2;
}

@keyframes floatBG {
  from { transform: scale(1); filter: blur(0px); }
  to { transform: scale(1.05); filter: blur(1px); }
}

/* 🫧 FLOATING BUBBLES */
.bubble {
  position: absolute;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  box-shadow: 0 0 10px rgba(255,255,255,0.4);
  cursor: pointer;
  animation: rise 10s linear forwards;
}

@keyframes rise {
  from { transform: translateY(100vh); opacity: 1; }
  to { transform: translateY(-10vh); opacity: 0; }
}

/* 🔐 LOGIN */
#lock {
  position: fixed;
  inset: 0;
  background: rgba(10,20,40,0.75);
  backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

input {
  padding: 12px;
  border-radius: 12px;
  border: none;
  margin-top: 10px;
  width: 220px;
  text-align: center;
}

/* 🪟 DESKTOP AREA */
#desktop {
  display: none;
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* 🪟 WINDOW STYLE */
.window {
  position: absolute;
  width: 260px;
  padding: 15px;
  border-radius: 16px;
  background: rgba(255,255,255,0.18);
  backdrop-filter: blur(15px);
  border: 1px solid rgba(255,255,255,0.4);
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  cursor: grab;
}

.window:active {
  cursor: grabbing;
}

.title {
  font-weight: bold;
  margin-bottom: 8px;
}

/* 💖 HEART BUTTON */
.btn {
  margin-top: 10px;
  padding: 8px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(90deg,#7dd3fc,#a78bfa);
  cursor: pointer;
}
</style>
</head>

<body>

<div class="bg"></div>

<!-- 🔐 LOCK SCREEN -->
<div id="lock">
  <h2>💙 Love OS Aero Login</h2>
  <p>Enter the phrase that started everything</p>
  <input id="pass" placeholder="password"/>
  <button class="btn" onclick="unlock()">Enter</button>
</div>

<!-- 🖥 DESKTOP -->
<div id="desktop">

<div class="window" style="top:60px;left:80px" onmousedown="drag(this)">
  <div class="title">💌 Memory Core</div>
  <div>Every version of me chooses you.</div>
  <button class="btn" onclick="popup('You are my safest timeline.')">Open</button>
</div>

<div class="window" style="top:200px;left:300px" onmousedown="drag(this)">
  <div class="title">💖 Emotion Log</div>
  <div>You feel like home coded into reality.</div>
  <button class="btn" onclick="popup('I would still choose you.')">Open</button>
</div>

<div class="window" style="top:120px;left:550px" onmousedown="drag(this)">
  <div class="title">🌊 System Note</div>
  <div>This love runs deeper than data.</div>
  <button class="btn" onclick="popup('Forever is already running.')">Open</button>
</div>

</div>

<script>

/* 🔐 UNLOCK */
function unlock(){
  let val = document.getElementById("pass").value.toLowerCase().trim();

  if(val.includes("i love you")){
    document.getElementById("lock").style.display = "none";
    document.getElementById("desktop").style.display = "block";
  } else {
    alert("try again 💙");
  }
}

/* 💬 POPUP */
function popup(text){
  alert(text);
}

/* 🪟 DRAG WINDOWS */
let active = null;
let offsetX = 0;
let offsetY = 0;

function drag(el){
  active = el;
  offsetX = event.clientX - el.offsetLeft;
  offsetY = event.clientY - el.offsetTop;
}

document.addEventListener("mousemove", (e)=>{
  if(active){
    active.style.left = (e.clientX - offsetX) + "px";
    active.style.top = (e.clientY - offsetY) + "px";
  }
});

document.addEventListener("mouseup", ()=>{
  active = null;
});

/* 🫧 BUBBLES GENERATOR */
setInterval(()=>{
  const b = document.createElement("div");
  b.className = "bubble";
  b.style.left = Math.random()*100 + "vw";
  b.style.animationDuration = (6 + Math.random()*6) + "s";

  b.onclick = () => alert("💙 memory unlocked");

  document.body.appendChild(b);
  setTimeout(()=>b.remove(),12000);
}, 500);

</script>

</body>
</html>
